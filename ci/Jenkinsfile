pipeline {
    agent any

    environment {
        IMAGE_NAME = "myapp:${BUILD_NUMBER}"   // unique tag per build
        FAIL_SEVERITY = "HIGH,CRITICAL"
    }

    stages {
        stage('Build Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME .'
            }
        }

        stage('Security Scan') {
            steps {
                // Save full report as a build artifact
                sh 'trivy image --format json --output scan-report.json $IMAGE_NAME'
                archiveArtifacts artifacts: 'scan-report.json'

                // The gate: fail build on HIGH/CRITICAL
                sh 'trivy image --exit-code 1 --severity $FAIL_SEVERITY $IMAGE_NAME'
            }
        }

        stage('Push to Registry') {
            steps {
                echo '✅ Scan passed — image is safe. (Push step would go here)'
            }
        }
    }

    post {
        failure {
            echo '🚨 Build blocked: vulnerabilities exceed the allowed threshold!'
        }
    }
}